generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model Advertiser {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  name           String
  hashPassword   String
  phone          String
  lastLoginAt    DateTime?
  isVerifiedByAdmin     Boolean
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company[]
    ad            Ad[]
  bid   Bid[]

}

model Admin {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  name           String
  department     String
  phone          String
  hashPassword   String
  lastLoginAt    DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  auctions        Auctions[]
  company         Company[]
  adSpaces       Ad_Space[]
  adSpaceImages       Ad_Space_Images[]
}


model Company {

    id      Int       @id @default(autoincrement())
    advertiser_id      Int
    
    companyName      String
    phone             String
    alternatePhone   String
    addressLine1     String
    city            String
    postalCode       String
    country         String
    company_licence   String
    logoUrl          String
    industryType     String
    verifiedByAdmin   Int?
    verficationDate   DateTime?
    status          String
    rejectionReason   String?
    createdAt         DateTime @default(now())
    updatedAt       DateTime  @updatedAt
    admin       Admin?     @relation(fields:[verifiedByAdmin],references:[id])
    advertiser        Advertiser  @relation(fields:[advertiser_id], references:[id])
  bid           Bid[]
  ad            Ad[]
}

model Ad_Space {
  id             Int      @id @default(autoincrement())
  title          String
  description    String
  address        String
  city           String
  width          Int
  height         Int
  basePrice      Int
  status         String   @default("available")
  createdByAdmin Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  adSpaceSmages   Ad_Space_Images[]
  admin          Admin    @relation(fields: [createdByAdmin], references: [id])
  auctions        Auctions[]
  ad              Ad[]
}

model Ad_Space_Images {
  id    Int       @id @default(autoincrement())
  adSpaceId     Int
  imgUrl     String
  thumnail    String
  isPrimary   String
  caption     String
  uploadedByAdmin   Int
  createdAt     DateTime @default(now())

  adSpace   Ad_Space  @relation(fields:[adSpaceId], references:[id])
  admin      Admin       @relation(fields:[uploadedByAdmin], references:[id])

}

model Auctions {
  id    Int   @id @default(autoincrement())
  adSpaceId     Int       
  startingTime    DateTime                
  endingTime      DateTime
  displayDurationDays   Int
  startingPrice   Int
  currentHeighestBid    Int
  minimumIncrement    Int
  bidCount    Int
  status  String
  createdByAdmin    Int
  cancelled_reason    String
 createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt 
   admin     Admin     @relation(fields:[createdByAdmin], references:[id])
  adSpace     Ad_Space    @relation(fields:[adSpaceId],references:[id])
  bid   Bid[]
  ad    Ad[]
}

model Bid {
  id   Int  @id @default(autoincrement())
  auctionId   Int 
  advertiserId  Int 
  companyId   Int 
  bidAmount   Int
  bidTime     Int
  status      String
  createdAt   String

  auctions     Auctions @relation(fields:[auctionId], references:[id])
  company     Company     @relation(fields:[companyId],references:[id])
  advertiser   Advertiser   @relation(fields:[advertiserId], references:[id])

}

model Ad {
  id     Int   @id @default(autoincrement())
  auctionId     Int
  advertiserId  Int
  companyId     Int
  adSpaceId     Int
  title       String
  description   String
  mediaUrl       String
  thumnailUrl     String
  status        String
  createdAt       DateTime @default(now())

  auctions     Auctions    @relation(fields:[auctionId], references: [id])
  advertiser      Advertiser      @relation(fields:[advertiserId], references:[id])
  company       Company         @relation(fields:[companyId], references:[id])
  adSpace       Ad_Space         @relation(fields:[adSpaceId], references:[id])




}



